{
  "name": "@focus-shield/storage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gamification/xp-system": {
      "types": "./dist/gamification/xp-system.d.ts",
      "import": "./dist/gamification/xp-system.js"
    },
    "./gamification/achievements": {
      "types": "./dist/gamification/achievements.d.ts",
      "import": "./dist/gamification/achievements.js"
    },
    "./gamification/streaks": {
      "types": "./dist/gamification/streaks.d.ts",
      "import": "./dist/gamification/streaks.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@focus-shield/shared-types": "workspace:*",
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
