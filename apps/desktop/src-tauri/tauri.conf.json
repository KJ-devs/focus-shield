{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-web/refs/heads/develop/nicegram.app/packages/tauri/tooling/cli/schema.json",
  "productName": "Focus Shield",
  "version": "0.1.0",
  "identifier": "com.focusshield.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev"
  },
  "app": {
    "windows": [
      {
        "title": "Focus Shield",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/focus-shield-daemon"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
